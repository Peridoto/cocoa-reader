{
  "name": "cocoa-reader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:static": "npm run build:static:setup && next build && npm run build:static:cleanup",
    "build:static:setup": "cp next.config.static.js next.config.js && cp src/app/page-static.tsx src/app/page.tsx && mv src/app/api src/api-backup && mv src/app/read src/read-backup",
    "build:static:cleanup": "cp src/app/page-dynamic.tsx.bak src/app/page.tsx && mv src/api-backup src/app/api && mv src/read-backup src/app/read",
    "build:server": "next build",
    "start": "next start",
    "export": "next export",
    "lint": "next lint",
    "build:ios": "./build-ios.sh",
    "ios:open": "npx cap open ios",
    "ios:sync": "npx cap sync ios",
    "ios:run": "npx cap run ios",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && next build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "demo:ethics": "tsx demo-ethics.js",
    "test:live": "node test-live-ethics.js",
    "ios:validate": "node ios-app-validation.js",
    "ios:test": "node ios-comprehensive-test-suite.js",
    "ios:performance": "node ios-performance-config.js",
    "ios:debug": "node ios-debug.js",
    "ios:sandbox-test": "node ios-sandbox-error-test.js"
  },
  "dependencies": {
    "@capacitor/browser": "^7.0.1",
    "@capacitor/cli": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "@capacitor/filesystem": "^7.1.1",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/share": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@heroicons/react": "^2.2.0",
    "@mozilla/readability": "^0.5.0",
    "@prisma/client": "^5.14.0",
    "jsdom": "^24.1.0",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.11.0",
    "typescript": "^5",
    "vitest": "^1.6.0",
    "workbox-cli": "^7.1.0",
    "workbox-webpack-plugin": "^7.1.0"
  }
}
