// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data/readlater.db"
}

model Article {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  domain      String
  excerpt     String?
  cleanedHTML String
  textContent String
  createdAt   DateTime @default(now())
  read        Boolean  @default(false)
  scroll      Int      @default(0) // 0-100
  
  @@map("articles")
}
