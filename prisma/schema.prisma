// This is your Prisma schema file for Vercel deployment
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String
  domain      String
  excerpt     String?
  cleanedHTML String
  textContent String
  createdAt   DateTime @default(now())
  read        Boolean  @default(false)
  scroll      Int      @default(0) // 0-100
  
  // AI Processing fields
  summary         String?  // AI-generated summary
  keyPoints       String?  // JSON array of key points
  readingTime     Int?     // Estimated reading time in minutes
  sentiment       String?  // positive, negative, neutral
  primaryCategory String?  // Main category
  categories      String?  // JSON array of categories
  tags           String?  // JSON array of tags
  aiProcessed    Boolean  @default(false) // Whether AI processing is complete
  
  @@index([createdAt])
  @@index([read])
  @@index([domain])
}
